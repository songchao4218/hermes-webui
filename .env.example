# Hermes WebUI - Environment Variables
# Copy this to .env and customize

# Ollama base URL (overrides config.yaml)
# OLLAMA_BASE_URL=http://localhost:11434

# Additional CORS origins (comma-separated)
# HERMES_CORS_ORIGINS=http://192.168.1.100:8080,http://myhost:8080

# Proxy settings (for GitHub API update checks)
# https_proxy=http://proxy:8080

# Hermes home directory (default: ~/.hermes)
# HERMES_HOME=~/.hermes
